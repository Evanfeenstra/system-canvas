{
  "name": "system-canvas-standalone",
  "version": "0.1.3",
  "description": "Self-contained browser bundle for system-canvas. Drop-in <script> tag with React inlined; renders a fully interactive canvas into any DOM element.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/system-canvas.js",
  "files": ["dist"],
  "keywords": ["canvas", "diagram", "svg", "json-canvas", "cdn", "standalone", "iife"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "system-canvas": "^0.1.0",
    "system-canvas-react": "^0.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0"
  }
}
